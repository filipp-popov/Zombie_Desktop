[
    {
        "name": "Режимы игры",
        "events": {
            "game_status": {
                "default_value": "maintenance",
                "type": "predefined",
                "possible_values": [
                    "maintenance",
                    "ready",
                    "game_started"
                ],
                "can_send_to_control_unit": true,
                "description": "Текущий режим игры"
            }
        }
    },
    {
        "name": "Пневмопочта на отправку",
        "events": {
            "key_air_tube_correct_input": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": false,
                "description": "Колба с правильным предметом появилась/исчезла"
            },
            "key_air_tube_button_pressed": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": false,
                "description": "Нажата кнопка отправки"
            },
            "key_air_tube_building_value": {
                "default_value": "",
                "type": "string",
                "can_send_to_control_unit": true,
                "description": "Значение Корпус изменено"
            },
            "key_air_tube_floor_value": {
                "default_value": "",
                "type": "string",
                "can_send_to_control_unit": true,
                "description": "Значение Этаж изменено"
            },
            "key_air_tube_room_value": {
                "default_value": "",
                "type": "string",
                "can_send_to_control_unit": true,
                "description": "Значение Помещение изменено"
            },
            "key_air_tube_lock_on": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": true,
                "description": "Включение/выключение магнита на дверце для колбы"
            },
            "key_air_tube_completed": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": false,
                "description": "Успешный исход"
            },
            "key_air_tube_wrong_item": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": false,
                "description": "Правильный адресат, неправильный предмет"
            }
        }
    },
    {
        "name": "Пневмопочта на получение от девочки",
        "events": {
            "girl_air_tube_lock_on": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": true,
                "description": "Магнитный замок включен/выключен"
            }
        }
    },
    {
        "name": "Пневмопочта на получение финальной карточки",
        "events": {
            "final_card_air_tube_lock_on": {
                "default_value": false,
                "type": "boolean",
                "can_send_to_control_unit": true,
                "description": "Магнитный замок включен/выключен"
            }
        }
    },
